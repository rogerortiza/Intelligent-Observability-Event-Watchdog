# ──────────────────────────────────────────────────────────
# Intelligent Observability & Event Watchdog — Environment
# Copy this file to .env and fill in the required values.
# .env is git-ignored; never commit real credentials.
# ──────────────────────────────────────────────────────────

# ── Database (REQUIRED) ────────────────────────────────────
# Supabase PostgreSQL connection string.
# Find it in: Supabase dashboard → Settings → Database → URI
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Application ────────────────────────────────────────────
# Set to true to enable SQLAlchemy query logging (verbose).
DEBUG=false

# ── Anomaly Detection Thresholds ──────────────────────────
# Tier 1 — Hard Threshold
# Number of errors in one metric window that triggers an alert.
ERROR_COUNT_THRESHOLD=10

# Fraction of logs that are errors before alerting (0.0–1.0).
ERROR_RATE_THRESHOLD=0.25

# Average latency in milliseconds above which a spike is flagged.
LATENCY_THRESHOLD_MS=2000

# Tier 2 — Z-score Statistical Detection
# Standard deviations above baseline mean to trigger an alert.
ZSCORE_THRESHOLD=2.5

# Z-score threshold specifically for log volume spikes.
VOLUME_ZSCORE_THRESHOLD=3.0

# ── Watchdog Scheduler ────────────────────────────────────
# How often (seconds) the background watchdog cycle runs.
WATCHDOG_INTERVAL_SECONDS=60

# Size of each aggregation window (minutes).
METRIC_WINDOW_MINUTES=5

# Number of prior windows used to compute the statistical baseline.
BASELINE_LOOKBACK_WINDOWS=60

# Tier 3 — IsolationForest
# Minimum number of historical windows required before the
# IsolationForest model is fitted and used for detection.
ISOLATION_FOREST_MIN_SAMPLES=20

# ── Streamlit Dashboard ───────────────────────────────────
# Base URL of the running FastAPI server.
# Change to the deployed URL when hosting remotely.
API_BASE_URL=http://localhost:8000

# ── Test Database (used by pytest only) ───────────────────
# Points to a local SQLite file; never runs against Supabase.
TEST_DATABASE_URL=sqlite:///./test_watchdog.db
